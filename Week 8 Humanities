                <div class="notebook-line"></div>
                <div class="notebook-line" style="text-align: center; padding-left: 0;"><span class="title-text" id="mock-title-box">TEXT TITLE</span></div>
                <div class="notebook-line"></div>
                <div class="notebook-line"><span class="question-text">1. Copy full question 1 here?</span></div>
                <div class="notebook-line"><span class="answer-prompt">Your full sentence answer here.</span></div>
                <div class="notebook-line"><span class="question-text">2. Copy full question 2 here?</span></div>
                <div class="notebook-line"><span class="answer-prompt">Your full sentence answer here.</span></div>
